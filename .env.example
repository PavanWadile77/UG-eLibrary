# Firebase Client Configuration (Flutter and Admin Panel)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here

# Algolia Configuration
ALGOLIA_APPLICATION_ID=your_algolia_app_id_here
ALGOLIA_SEARCH_API_KEY=your_algolia_search_key_here
ALGOLIA_ADMIN_API_KEY=your_algolia_admin_key_here

# Firebase Cloud Messaging (FCM) Server Key (Legacy or V1 config)
FCM_SERVER_KEY=your_fcm_server_key_here

# Admin Panel Security
ADMIN_PANEL_SECRET=your_admin_panel_secret_here

# General Token Signing (JWT)
JWT_SECRET=your_jwt_secret_here

# Google Maps API Key (If used in college locations)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Google Gemini API Key (Used for AI Summaries and AI Question Generator)
GEMINI_API_KEY=your_gemini_api_key_here
