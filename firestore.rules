rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Functions for role checking
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // User can create and update their own profile, but cannot assign 'admin' role
      allow create, update: if (request.auth.uid == userId && request.resource.data.role != 'admin') || isAdmin();
      allow delete: if isAdmin();
    }

    // Resources Collection
    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      // Teachers can upload, but initially it must be pending
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.uploadedBy == request.auth.uid);
    }

    // Notifications Collection
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Subjects Collection
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // System Settings / Colleges / Branches
    match /{collection}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
